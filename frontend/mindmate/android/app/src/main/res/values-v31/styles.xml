<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">true</item>

        <!-- Android 12+ Splash Screen items -->
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <!-- Hiding the splash icon by using a transparent drawable -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/transparent_pixel</item>
        <!-- Making the icon background black as well to hide any remaining circle -->
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/black</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
